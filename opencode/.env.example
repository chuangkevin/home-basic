# Copy this file to .env and fill in the keys you need.
# All keys are optional — the service starts without any of them.
# Default model is opencode/deepseek-v4-flash-free (free, no key required).

# Uncomment to use OpenAI models (gpt-4o, etc.)
# OPENAI_API_KEY=sk-...

# Uncomment to use Gemini models
# GEMINI_API_KEY=...

# Uncomment to use Anthropic models
# ANTHROPIC_API_KEY=sk-ant-...
